{
  "name": "cortex",
  "version": "1.0.0",
  "description": "Persistent memory and context layer for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cortex-mcp": "dist/mcp/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start:mcp": "node dist/mcp/server.js",
    "dev:mcp": "tsx src/mcp/server.ts",
    "test": "tsx test.ts",
    "test:runner": "tsx test-runner.ts",
    "watch": "tsc && node dist/watcher.js"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
